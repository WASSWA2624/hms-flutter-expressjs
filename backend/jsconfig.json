{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@app/*": ["src/app/*"],
      "@lib/*": ["src/lib/*"],
      "@middlewares/*": ["src/middlewares/*"],
      "@config/*": ["src/config/*"],
      "@prisma/client": ["src/prisma/client.js"],
      "@logs/*": ["logs/*"],
      "@websockets/*": ["src/websockets/*"],
      "@modules/*": ["src/modules/*"]
    }
  },
  "exclude": ["node_modules", "logs"]
}
