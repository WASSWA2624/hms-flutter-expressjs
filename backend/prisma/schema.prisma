model lab_result {
  id                String          @id @default(uuid()) @db.VarChar(36)
  human_friendly_id String?         @db.VarChar(32)
  lab_order_item_id String          @db.VarChar(36)
  status            LabResultStatus
  result_value      String?         @db.VarChar(120)
  result_unit       String?         @db.VarChar(40)
  result_flag       String?         @db.VarChar(40)
  is_positive       Boolean         @default(false)
  reference_range_label   String?   @db.VarChar(120)
  reference_range_summary String?   @db.VarChar(255)
  result_text       String?         @db.Text
  reported_at       DateTime?
  created_at        DateTime        @default(now())
  updated_at        DateTime        @updatedAt
  deleted_at        DateTime?
  version           Int             @default(1)

  lab_order_item lab_order_item @relation(fields: [lab_order_item_id], references: [id])

  @@unique([human_friendly_id])
  @@index([lab_order_item_id])
  @@index([status])
  @@index([reported_at])
  @@index([deleted_at])
  @@index([human_friendly_id])
}

model lab_qc_log {
  id                String    @id @default(uuid()) @db.VarChar(36)
  human_friendly_id String?   @db.VarChar(32)
  lab_test_id       String    @db.VarChar(36)
  status            String?   @db.VarChar(80)
  notes             String?   @db.Text
  logged_at         DateTime  @default(now())
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  deleted_at        DateTime?
  version           Int       @default(1)

  lab_test lab_test @relation(fields: [lab_test_id], references: [id])

  @@unique([human_friendly_id])
  @@index([lab_test_id])
  @@index([logged_at])
  @@index([deleted_at])
  @@index([human_friendly_id])
}

model radiology_test {
  id                String          @id @default(uuid()) @db.VarChar(36)
  human_friendly_id String?         @db.VarChar(32)
  tenant_id         String          @db.VarChar(36)
  name              String          @db.VarChar(255)
  code              String?         @db.VarChar(80)
  modality          ImagingModality
  created_at        DateTime        @default(now())
  updated_at        DateTime        @updatedAt
  deleted_at        DateTime?
  version           Int             @default(1)

  tenant tenant            @relation(fields: [tenant_id], references: [id])
  orders radiology_order[]

  @@index([tenant_id])
  @@index([code])
  @@index([modality])
  @@index([deleted_at])
  @@index([human_friendly_id])
}

model radiology_order {
  id                String               @id @default(uuid()) @db.VarChar(36)
  human_friendly_id String?              @db.VarChar(32)
  encounter_id      String?              @db.VarChar(36)
  patient_id        String               @db.VarChar(36)
  radiology_test_id String?              @db.VarChar(36)
  status            RadiologyOrderStatus
  clinical_note     String?              @db.Text
  request_details   Json?
  ordered_at        DateTime             @default(now())
  created_at        DateTime             @default(now())
  updated_at        DateTime             @updatedAt
  deleted_at        DateTime?
  version           Int                  @default(1)

  encounter       encounter?         @relation(fields: [encounter_id], references: [id])
  patient         patient            @relation(fields: [patient_id], references: [id])
  radiology_test  radiology_test?    @relation(fields: [radiology_test_id], references: [id])
  results         radiology_result[]
  imaging_studies imaging_study[]

  @@index([encounter_id])
  @@index([patient_id])
  @@index([radiology_test_id])
  @@index([status])
  @@index([ordered_at])
  @@index([deleted_at])
  @@index([human_friendly_id])
}

model radiology_result {
  id                 String                @id @default(uuid()) @db.VarChar(36)
  human_friendly_id  String?               @db.VarChar(32)
  radiology_order_id String                @db.VarChar(36)
  status             RadiologyReportStatus
  report_text        String?               @db.Text
  reported_at        DateTime?
  created_at         DateTime              @default(now())
  updated_at         DateTime              @updatedAt
  deleted_at         DateTime?
  version            Int                   @default(1)

  radiology_order radiology_order                @relation(fields: [radiology_order_id], references: [id])
  attestations    radiology_result_attestation[]

  @@index([radiology_order_id])
  @@index([status])
  @@index([reported_at])
  @@index([deleted_at])
  @@index([human_friendly_id])
}

model imaging_study {
  id                 String          @id @default(uuid()) @db.VarChar(36)
  human_friendly_id  String?         @db.VarChar(32)
  radiology_order_id String          @db.VarChar(36)
  modality           ImagingModality
  performed_at       DateTime?
  created_at         DateTime        @default(now())
  updated_at         DateTime        @updatedAt
  deleted_at         DateTime?
  version            Int             @default(1)

  radiology_order radiology_order @relation(fields: [radiology_order_id], references: [id])
  assets          imaging_asset[]
  pacs_links      pacs_link[]

  @@index([radiology_order_id])
  @@index([modality])
  @@index([performed_at])
  @@index([deleted_at])
  @@index([human_friendly_id])
}

model imaging_asset {
  id                String    @id @default(uuid()) @db.VarChar(36)
  human_friendly_id String?   @db.VarChar(32)
  imaging_study_id  String    @db.VarChar(36)
  storage_key       String    @db.VarChar(255)
  file_name         String?   @db.VarChar(255)
  content_type      String?   @db.VarChar(120)
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  deleted_at        DateTime?
  version           Int       @default(1)

  imaging_study imaging_study @relation(fields: [imaging_study_id], references: [id])

  @@index([imaging_study_id])
  @@index([deleted_at])
  @@index([human_friendly_id])
}

model pacs_link {
  id                String    @id @default(uuid()) @db.VarChar(36)
  human_friendly_id String?   @db.VarChar(32)
  imaging_study_id  String    @db.VarChar(36)
  url               String    @db.VarChar(255)
  expires_at        DateTime?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  deleted_at        DateTime?
  version           Int       @default(1)

  imaging_study imaging_study @relation(fields: [imaging_study_id], references: [id])

  @@index([imaging_study_id])
  @@index([expires_at])
  @@index([deleted_at])
  @@index([human_friendly_id])
}

model drug {
  id                String    @id @default(uuid()) @db.VarChar(36)
  human_friendly_id String?   @db.VarChar(32)
  tenant_id         String    @db.VarChar(36)
  name              String    @db.VarChar(255)
  code              String?   @db.VarChar(80)
  form              String?   @db.VarChar(80)
  strength          String?   @db.VarChar(80)
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  deleted_at        DateTime?
  version           Int       @default(1)

  tenant               tenant                @relation(fields: [tenant_id], references: [id])
  batches              drug_batch[]
  formulary_items      formulary_item[]
  pharmacy_order_items pharmacy_order_item[]
  adverse_events       adverse_event[]
  inventory_maps       drug_inventory_map[]

  @@index([tenant_id])
  @@index([code])
  @@index([deleted_at])
  @@index([human_friendly_id])
}

model drug_batch {
  id                String    @id @default(uuid()) @db.VarChar(36)
  human_friendly_id String?   @db.VarChar(32)
  drug_id           String    @db.VarChar(36)
  batch_number      String    @db.VarChar(80)
  expiry_date       DateTime?
  quantity          Int       @default(0)
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  deleted_at        DateTime?
  version           Int       @default(1)

  drug drug @relation(fields: [drug_id], references: [id])

  @@index([drug_id])
  @@index([batch_number])
  @@index([expiry_date])
  @@index([deleted_at])
  @@index([human_friendly_id])
}

model formulary_item {
  id                String    @id @default(uuid()) @db.VarChar(36)
  human_friendly_id String?   @db.VarChar(32)
  tenant_id         String    @db.VarChar(36)
  drug_id           String    @db.VarChar(36)
  is_active         Boolean   @default(true)
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  deleted_at        DateTime?
  version           Int       @default(1)

  tenant tenant @relation(fields: [tenant_id], references: [id])
  drug   drug   @relation(fields: [drug_id], references: [id])

  @@index([tenant_id])
  @@index([drug_id])
  @@index([is_active])
  @@index([deleted_at])
  @@index([human_friendly_id])
}

model pharmacy_order {
  id                String              @id @default(uuid()) @db.VarChar(36)
  human_friendly_id String?             @db.VarChar(32)
  encounter_id      String?             @db.VarChar(36)
  patient_id        String              @db.VarChar(36)
  status            PharmacyOrderStatus
  ordered_at        DateTime            @default(now())
  created_at        DateTime            @default(now())
  updated_at        DateTime            @updatedAt
  deleted_at        DateTime?
  version           Int                 @default(1)

  encounter             encounter?                      @relation(fields: [encounter_id], references: [id])
  patient               patient                         @relation(fields: [patient_id], references: [id])
  items                 pharmacy_order_item[]
  dispense_attestations pharmacy_dispense_attestation[]

  @@index([encounter_id])
  @@index([patient_id])
  @@index([status])
  @@index([ordered_at])
  @@index([deleted_at])
  @@index([human_friendly_id])
}

model pharmacy_order_item {
  id                String               @id @default(uuid()) @db.VarChar(36)
  human_friendly_id String?              @db.VarChar(32)
  pharmacy_order_id String               @db.VarChar(36)
  drug_id             String               @db.VarChar(36)
  quantity            Int
  quantity_unit       String?              @db.VarChar(40)
  dosage              String?              @db.VarChar(80)
  dose_amount         Decimal?             @db.Decimal(10, 3)
  dose_unit           String?              @db.VarChar(40)
  frequency           MedicationFrequency?
  route               MedicationRoute?
  duration_value      Int?
  duration_unit       String?              @db.VarChar(40)
  instructions        String?              @db.Text
  custom_prescription String?              @db.Text
  status            PrescriptionStatus   @default(ACTIVE)
  created_at        DateTime             @default(now())
  updated_at        DateTime             @updatedAt
  deleted_at        DateTime?
  version           Int                  @default(1)

  pharmacy_order pharmacy_order @relation(fields: [pharmacy_order_id], references: [id])
  drug           drug           @relation(fields: [drug_id], references: [id])
  dispense_logs  dispense_log[]

  @@index([pharmacy_order_id])
  @@index([drug_id])
  @@index([status])
  @@index([dose_unit])
  @@index([duration_unit])
  @@index([deleted_at])
  @@index([human_friendly_id])
}

model dispense_log {
  id                     String         @id @default(uuid()) @db.VarChar(36)
  human_friendly_id      String?        @db.VarChar(32)
  pharmacy_order_item_id String         @db.VarChar(36)
  dispense_batch_ref     String?        @db.VarChar(64)
  status                 DispenseStatus
  dispensed_at           DateTime?
  quantity_dispensed     Int            @default(0)
  created_at             DateTime       @default(now())
  updated_at             DateTime       @updatedAt
  deleted_at             DateTime?
  version                Int            @default(1)

  pharmacy_order_item pharmacy_order_item @relation(fields: [pharmacy_order_item_id], references: [id])

  @@index([pharmacy_order_item_id])
  @@index([dispense_batch_ref])
  @@index([status])
  @@index([dispensed_at])
  @@index([deleted_at])
  @@index([human_friendly_id])
}

model adverse_event {
  id                String          @id @default(uuid()) @db.VarChar(36)
  human_friendly_id String?         @db.VarChar(32)
  patient_id        String          @db.VarChar(36)
  drug_id           String?         @db.VarChar(36)
  severity          AllergySeverity
  description       String?         @db.Text
  reported_at       DateTime        @default(now())
  created_at        DateTime        @default(now())
  updated_at        DateTime        @updatedAt
  deleted_at        DateTime?
  version           Int             @default(1)

  patient patient @relation(fields: [patient_id], references: [id])
  drug    drug?   @relation(fields: [drug_id], references: [id])

  @@index([patient_id])
  @@index([drug_id])
  @@index([severity])
  @@index([reported_at])
  @@index([deleted_at])
  @@index([human_friendly_id])
}

model inventory_item {
  id                String            @id @default(uuid()) @db.VarChar(36)
  human_friendly_id String?           @db.VarChar(32)
  tenant_id         String            @db.VarChar(36)
  name              String            @db.VarChar(255)
  category          InventoryCategory
  sku               String?           @db.VarChar(80)
  unit              String?           @db.VarChar(40)
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt
  deleted_at        DateTime?
  version           Int               @default(1)

  tenant            tenant               @relation(fields: [tenant_id], references: [id])
  stocks            inventory_stock[]
  movements         stock_movement[]
  stock_adjustments stock_adjustment[]
  drug_maps         drug_inventory_map[]

  @@index([tenant_id])
  @@index([category])
  @@index([sku])
  @@index([deleted_at])
  @@index([human_friendly_id])
}

model radiology_result_attestation {
  id                  String                          @id @default(uuid()) @db.VarChar(36)
  human_friendly_id   String?                         @db.VarChar(32)
  radiology_result_id String                          @db.VarChar(36)
  phase               RadiologyResultAttestationPhase
  attested_by_user_id String                          @db.VarChar(36)
  attested_role       String?                         @db.VarChar(80)
  statement           String?                         @db.Text
  reason              String?                         @db.VarChar(255)
  ip_address          String?                         @db.VarChar(64)
  attested_at         DateTime                        @default(now())
  created_at          DateTime                        @default(now())
  updated_at          DateTime                        @updatedAt
  deleted_at          DateTime?
  version             Int                             @default(1)

  radiology_result radiology_result @relation(fields: [radiology_result_id], references: [id])

  @@unique([radiology_result_id, phase])
  @@index([radiology_result_id])
  @@index([phase])
  @@index([attested_by_user_id])
  @@index([deleted_at])
  @@index([human_friendly_id])
}

model pharmacy_dispense_attestation {
  id                  String                           @id @default(uuid()) @db.VarChar(36)
  human_friendly_id   String?                          @db.VarChar(32)
  pharmacy_order_id   String                           @db.VarChar(36)
  dispense_batch_ref  String                           @db.VarChar(64)
  phase               PharmacyDispenseAttestationPhase
  attested_by_user_id String                           @db.VarChar(36)
  attested_role       String?                          @db.VarChar(80)
  statement           String?                          @db.Text
  reason              String?                          @db.VarChar(255)
  ip_address          String?                          @db.VarChar(64)
  attested_at         DateTime                         @default(now())
  created_at          DateTime                         @default(now())
  updated_at          DateTime                         @updatedAt
  deleted_at          DateTime?
  version             Int                              @default(1)

  pharmacy_order pharmacy_order @relation(fields: [pharmacy_order_id], references: [id])

  @@unique([pharmacy_order_id, dispense_batch_ref, phase])
  @@index([pharmacy_order_id])
  @@index([dispense_batch_ref])
  @@index([phase])
  @@index([attested_by_user_id])
  @@index([deleted_at])
  @@index([human_friendly_id])
}

model drug_inventory_map {
  id                String    @id @default(uuid()) @db.VarChar(36)
  human_friendly_id String?   @db.VarChar(32)
  tenant_id         String    @db.VarChar(36)
  drug_id           String    @db.VarChar(36)
  inventory_item_id String    @db.VarChar(36)
  is_default        Boolean   @default(false)
  deduction_factor  Decimal   @default(1.0) @db.Decimal(10, 4)
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  deleted_at        DateTime?
  version           Int       @default(1)

  drug           drug           @relation(fields: [drug_id], references: [id])
  inventory_item inventory_item @relation(fields: [inventory_item_id], references: [id])

  @@unique([drug_id, inventory_item_id])
  @@index([tenant_id])
  @@index([drug_id])
  @@index([inventory_item_id])
  @@index([is_default])
  @@index([deleted_at])
  @@index([human_friendly_id])
}

model inventory_stock {
  id                String    @id @default(uuid()) @db.VarChar(36)
  human_friendly_id String?   @db.VarChar(32)
  inventory_item_id String    @db.VarChar(36)
  facility_id       String?   @db.VarChar(36)
  quantity          Int       @default(0)
