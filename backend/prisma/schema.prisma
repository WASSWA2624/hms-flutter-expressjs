model human_id_counter {
  id                String    @id @default(uuid()) @db.VarChar(36)
  human_friendly_id String?   @db.VarChar(32)
  model_name        String    @db.VarChar(80)
  prefix            String    @db.VarChar(16)
  scope_key         String    @db.VarChar(160)
  last_value        Int       @default(0)
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  deleted_at        DateTime?
  version           Int       @default(1)

  @@unique([model_name, prefix, scope_key])
  @@index([deleted_at])
  @@index([human_friendly_id])
}

