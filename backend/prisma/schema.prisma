enum MortuaryCaseStatus {
  RECEIVED
  IDENTIFICATION_PENDING
  IN_STORAGE
  POST_MORTEM_PENDING
  READY_FOR_RELEASE
  RELEASED
  CLOSED
  CANCELLED
}

enum MortuaryIdentificationStatus {
  UNVERIFIED
  PARTIAL
  VERIFIED
}

enum MortuaryStorageSlotStatus {
  AVAILABLE
  OCCUPIED
  HELD
  OUT_OF_SERVICE
  CLEANING
}

enum MortuaryCustodyEventType {
  RECEIVED
  STORAGE_ASSIGNED
  TRANSFERRED
  VIEWING
  POST_MORTEM_TRANSFER
  DOCUMENT_UPDATED
  RELEASED
  CORRECTION
}

enum MortuaryPostMortemStatus {
  REQUESTED
  APPROVED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MortuaryReleaseStatus {
