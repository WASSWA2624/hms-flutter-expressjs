model facility {
  id                       String       @id @default(uuid()) @db.VarChar(36)
  human_friendly_id        String?      @db.VarChar(32)
  tenant_id                String       @db.VarChar(36)
  name                     String       @db.VarChar(255)
  facility_type            FacilityType
  is_active                Boolean      @default(true)
  extension_json           Json?
  configuration_version_id String?      @db.VarChar(36)
  created_at               DateTime     @default(now())
  updated_at               DateTime     @updatedAt
  deleted_at               DateTime?
  version                  Int          @default(1)

  tenant                          tenant                           @relation(fields: [tenant_id], references: [id])
  branches                        branch[]
  departments                     department[]
  units                           unit[]
  wards                           ward[]
  rooms                           room[]
  beds                            bed[]
  users                           user[]
  patients                        patient[]
  schedules                       provider_schedule[]
  appointments                    appointment[]
  encounters                      encounter[]
  admissions                      admission[]
  ambulances                      ambulance[]
  invoices                        invoice[]
  payments                        payment[]
  billing_approvals               billing_approval[]
  inventory_stocks                inventory_stock[]
  stock_movements                 stock_movement[]
  stock_adjustments               stock_adjustment[]
  purchase_requests               purchase_request[]
  visit_queue_entries             visit_queue[]
  emergency_cases                 emergency_case[]
  staff_positions                 staff_position[]
  user_profiles                   user_profile[]
  registration_follow_ups         registration_follow_up[]
  clinical_vital_alert_thresholds clinical_vital_alert_threshold[]
  clinical_term_favorites         clinical_term_favorite[]
  shifts                          shift[]
  nurse_rosters                   nurse_roster[]
  shift_templates                 shift_template[]
  housekeeping_tasks              housekeeping_task[]
  housekeeping_schedules          housekeeping_schedule[]
  maintenance_requests            maintenance_request[]
  assets                          asset[]
  addresses                       address[]                        @relation("facility_address")
  contacts                        contact[]                        @relation("facility_contact")
  report_definitions              report_definition[]              @relation("report_definition_facility")
  report_runs                     report_run[]                     @relation("report_run_facility")
  report_schedules                report_schedule[]                @relation("report_schedule_facility")
  kpi_snapshots                   kpi_snapshot[]                   @relation("kpi_snapshot_facility")
  analytics_events                analytics_event[]                @relation("analytics_event_facility")
  abac_policies                   abac_policy[]
  break_glass_accesses            break_glass_access[]
  office_contexts                 office_context[]
  shift_closes                    shift_close[]
  day_closes                      day_close[]
  handovers                       handover[]
  custody_snapshots               custody_snapshot[]
  closeout_packs                  closeout_pack[]
  unit_management_assignments     unit_management_assignment[]
  mortuary_deceased_profiles      mortuary_deceased_profile[]
  mortuary_cases                  mortuary_case[]
  mortuary_storage_units          mortuary_storage_unit[]
  mortuary_storage_slots          mortuary_storage_slot[]
  mortuary_storage_assignments    mortuary_storage_assignment[]
  mortuary_custody_events         mortuary_custody_event[]
  mortuary_viewings               mortuary_viewing[]
  mortuary_post_mortem_requests   mortuary_post_mortem_request[]
  mortuary_release_authorisations mortuary_release_authorisation[]
  mortuary_billable_events        mortuary_billable_event[]

  @@index([tenant_id])
  @@index([facility_type])
  @@index([configuration_version_id])
  @@index([deleted_at])
  @@index([human_friendly_id])
}

model branch {
  id                String    @id @default(uuid()) @db.VarChar(36)
  human_friendly_id String?   @db.VarChar(32)
  tenant_id         String    @db.VarChar(36)
  facility_id       String?   @db.VarChar(36)
  name              String    @db.VarChar(255)
  is_active         Boolean   @default(true)
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  deleted_at        DateTime?
  version           Int       @default(1)

  tenant      tenant       @relation(fields: [tenant_id], references: [id])
  facility    facility?    @relation(fields: [facility_id], references: [id])
  departments department[]
  addresses   address[]    @relation("branch_address")
  contacts    contact[]    @relation("branch_contact")
  kpi_snapshots kpi_snapshot[] @relation("kpi_snapshot_branch")
  analytics_events analytics_event[] @relation("analytics_event_branch")
  abac_policies      abac_policy[]
  break_glass_accesses break_glass_access[]
  office_contexts    office_context[]
  shift_closes       shift_close[]
  day_closes         day_close[]
  handovers          handover[]
  custody_snapshots  custody_snapshot[]
  closeout_packs     closeout_pack[]

  @@index([tenant_id])
  @@index([deleted_at])
  @@index([human_friendly_id])
}

model department {
  id                String         @id @default(uuid()) @db.VarChar(36)
  human_friendly_id String?        @db.VarChar(32)
  tenant_id         String         @db.VarChar(36)
  facility_id       String?        @db.VarChar(36)
  branch_id         String?        @db.VarChar(36)
  name              String         @db.VarChar(255)
  short_name        String?        @db.VarChar(50)
  department_type   DepartmentType
  is_active         Boolean        @default(true)
  created_at        DateTime       @default(now())
  updated_at        DateTime       @updatedAt
  deleted_at        DateTime?
  version           Int            @default(1)

  tenant            tenant             @relation(fields: [tenant_id], references: [id])
  facility          facility?          @relation(fields: [facility_id], references: [id])
  branch            branch?            @relation(fields: [branch_id], references: [id])
  units             unit[]
  wards             ward[]
  staff_positions   staff_position[]
  staff_profiles    staff_profile[]
  staff_assignments staff_assignment[]
  nurse_rosters     nurse_roster[]
  referrals_from    referral[]         @relation("referral_from_department")
  referrals_to      referral[]         @relation("referral_to_department")
  abac_policies     abac_policy[]
  unit_management_assignments unit_management_assignment[]

  @@index([tenant_id])
  @@index([branch_id])
  @@index([department_type])
  @@index([deleted_at])
  @@index([human_friendly_id])
}

