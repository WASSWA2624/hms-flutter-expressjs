{
  "name": "hms-backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "predev": "node scripts/release-port.js 3000",
    "start": "node src/server.js",
    "prestart": "node scripts/release-port.js 3000",
    "postinstall": "prisma generate",
    "test": "npm run test:backend",
    "test:watch": "npm run test:backend:watch",
    "test:coverage": "npm run test:backend:coverage",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "i18n:check": "node scripts/check-locales.js",
    "openapi:generate": "node scripts/generate-openapi.js",
    "openapi:validate": "node scripts/validate-openapi.js",
    "setup:accounts": "node scripts/setup-default-accounts.js",
    "db:backfill:ambulance-role": "node scripts/backfill-ambulance-operator-role.js",
    "db:backfill:vital-bp": "node scripts/backfill-vital-bp-components.js",
    "db:backfill:subscription-friendly-ids": "node scripts/backfill-subscription-friendly-ids.js",
    "db:backfill:user-position-title": "node scripts/backfill-user-position-title.js",
    "db:backfill:drug-inventory-map": "node scripts/backfill-drug-inventory-map.js",
    "db:report:user-position-title": "node scripts/report-user-position-title.js",
    "db:clear:demo": "node scripts/clear-demo-data.js --yes",
    "db:clear:demo:dry-run": "node scripts/clear-demo-data.js --dry-run",
    "db:seed:clinical-catalog": "node scripts/seed-clinical-catalog-data.js",
    "db:seed:lab-catalog": "node scripts/seed-lab-catalog-data.js",
    "db:seed:demo": "node scripts/seed-demo-data.js",
    "db:verify:demo": "node scripts/verify-demo-data.js",
    "db:reset:demo": "node scripts/clear-demo-data.js --yes && node scripts/seed-demo-data.js",
    "seed": "node prisma/seed.js",
    "prisma:studio": "prisma studio",
    "prisma:generate": "prisma generate",
    "prisma:generate:debug": "node scripts/prisma-runner.js generate",
    "prisma:check-hfid-collisions": "node prisma/scripts/check-friendly-id-collisions.js",
    "prisma:resolve-hfid-collisions": "node prisma/scripts/resolve-friendly-id-collisions.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:deploy:debug": "node scripts/prisma-runner.js migrate deploy",
    "startup:diagnostics": "node scripts/startup-diagnostics.js",
    "test:backend": "node scripts/run-jest.js",
    "test:backend:watch": "node scripts/run-jest.js --watch",
    "test:backend:coverage": "node scripts/run-jest.js --coverage",
    "test:backend:unit": "node scripts/run-jest.js --runInBand",
    "test:backend:integration": "node scripts/run-jest.js --testMatch \"**/src/tests/**/*.integration.test.js\" --runInBand --passWithNoTests",
    "test:backend:db:prepare": "node scripts/prepare-test-database.js",
    "test:all": "npm run lint && npm run test:backend && npm run openapi:validate",
    "typecheck": "npm run lint",
    "validate": "npm run test:all"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WASSWA2624/hms.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/WASSWA2624/hms/issues"
  },
  "homepage": "https://github.com/WASSWA2624/hms#readme",
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@prisma/adapter-mariadb": "7.1.0",
    "@prisma/client": "7.1.0",
    "@prisma/client-runtime-utils": "7.1.0",
    "argon2": "^0.44.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "module-alias": "^2.2.3",
    "multer": "^2.0.2",
    "mysql2": "^3.15.3",
    "nodemailer": "^6.10.1",
    "pdfkit": "^0.17.2",
    "prisma": "7.1.0",
    "ws": "^8.18.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@faker-js/faker": "^10.3.0",
    "eslint": "^9.39.2",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "prettier": "^3.7.4",
    "supertest": "^7.1.4"
  }
}
